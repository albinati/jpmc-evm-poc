# /etc/jpmc-evm-poc/secrets.env  (chmod 600)
#
# Three role keys. Override these with real keys held in the host's secret store. Defaults
# below are Hardhat well-known accounts — same as local dev — because the chain is private
# and the keys have no value off-network.

POC_BANKER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
POC_COMPLIANCE_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
POC_LIQUIDATION_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Optional legacy single-key fallback. Leave blank if you supplied the three above.
POC_SIGNER_PRIVATE_KEY=

# When the dev keys above are intentionally absent, set this to false to fail-fast instead of
# falling back to Hardhat well-known accounts.
POC_ALLOW_DEV_DEFAULTS=true

# Epoch seconds at which the next reset cron will fire — written by deploy/reset-demo.sh.
# Surfaced via /api/config so the UI can render a "next reset in HH:MM" badge.
POC_NEXT_RESET_AT=
