# Copy to .env for local tooling if desired (never commit real secrets).

# Hardhat / chain (optional overrides)
# RPC_URL=

# Spring Boot orchestration API
POC_RPC_URL=http://127.0.0.1:8545
POC_CHAIN_ID=31337
POC_DEPLOYMENTS_FILE=../deployments/local.json

# Three demo signer keys — one per role. If left blank and POC_ALLOW_DEV_DEFAULTS=true
# (the default), the API falls back to Hardhat well-known accounts #1 / #2 / #3.
POC_BANKER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
POC_COMPLIANCE_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
POC_LIQUIDATION_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Legacy single-key fallback. If a per-role key above is missing this one is used in its
# place — useful for backward compatibility but breaks segregation of duties.
# POC_SIGNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Set to false on production hosts to fail-fast when explicit keys are missing.
POC_ALLOW_DEV_DEFAULTS=true
